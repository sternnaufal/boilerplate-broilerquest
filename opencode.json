{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "gladekit": {
      "type": "local",
      "command": ["uvx", "gladekit-mcp"],
      "enabled": true
    },
    "sigmap": {
      "type": "local",
      "command": ["npx", "sigmap", "--mcp"],
      "enabled": true
    },
    "semble": {
      "type": "local",
      "command": ["uvx", "--from", "semble[mcp]", "semble"],
      "enabled": true
    }
  }
}
